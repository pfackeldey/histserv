    "@tsconfig/svelte": "^5.0.8",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "d3": "^7.9.0"
